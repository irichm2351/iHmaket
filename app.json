{
  "expo": {
    "name": "Ihmaket",
    "slug": "ihmaket",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/iHlogo1.png",
    "scheme": "ihmaket",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ihmaket.app"
    },
    "android": {
      "package": "com.ihmaket.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/iHlogo1.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e40af"
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "084cb782-8cd0-4892-8a3c-8b5ea3fa0936"
      }
    },
    "owner": "irichmoses"
  }
}
